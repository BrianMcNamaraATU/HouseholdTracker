<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HouseholdTracker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:HouseholdTracker.Pages"
    Shell.FlyoutBehavior="Disabled">

    <!-- Pre-login pages — hidden from flyout -->
    <ShellContent Route="LoadingPage"        ContentTemplate="{DataTemplate pages:LoadingPage}"        FlyoutItemIsVisible="False" Shell.FlyoutBehavior="Disabled" />
    <ShellContent Route="LoginPage"          ContentTemplate="{DataTemplate pages:LoginPage}"          FlyoutItemIsVisible="False" Shell.FlyoutBehavior="Disabled" />
    <ShellContent Route="RegisterPage"       ContentTemplate="{DataTemplate pages:RegisterPage}"       FlyoutItemIsVisible="False" Shell.FlyoutBehavior="Disabled" />
    <ShellContent Route="ForgotPasswordPage" ContentTemplate="{DataTemplate pages:ForgotPasswordPage}" FlyoutItemIsVisible="False" Shell.FlyoutBehavior="Disabled" />
    <ShellContent Route="ChangePasswordPage" ContentTemplate="{DataTemplate pages:ChangePasswordPage}" FlyoutItemIsVisible="False" Shell.FlyoutBehavior="Disabled" />

    <!-- Post-login pages — flyout menu enabled -->
    <FlyoutItem Title="My Tracking" Route="MyTrackingPage" Shell.FlyoutBehavior="Flyout">
        <ShellContent ContentTemplate="{DataTemplate pages:MyTrackingPage}" />
    </FlyoutItem>

</Shell>

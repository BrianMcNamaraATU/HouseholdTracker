<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ===================== -->
    <!-- Page Style            -->
    <!-- ===================== -->

    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource PageBackgroundColor}" />
    </Style>

    <!-- ===================== -->
    <!-- Label Styles          -->
    <!-- ===================== -->

    <Style x:Key="PageTitleStyle" TargetType="Label">
        <Setter Property="FontSize"          Value="28" />
        <Setter Property="FontAttributes"    Value="Bold" />
        <Setter Property="TextColor"         Value="{StaticResource PrimaryTextColor}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Margin"            Value="0,0,0,8" />
    </Style>

    <Style x:Key="PageSubtitleStyle" TargetType="Label">
        <Setter Property="FontSize"          Value="14" />
        <Setter Property="TextColor"         Value="{StaticResource SecondaryTextColor}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Margin"            Value="0,0,0,24" />
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="Label">
        <Setter Property="FontSize"       Value="13" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"      Value="{StaticResource PrimaryTextColor}" />
        <Setter Property="Margin"         Value="0,0,0,4" />
    </Style>

    <Style x:Key="ErrorLabelStyle" TargetType="Label">
        <Setter Property="FontSize"  Value="12" />
        <Setter Property="TextColor" Value="{StaticResource ErrorTextColor}" />
        <Setter Property="Margin"    Value="0,2,0,6" />
    </Style>

    <Style x:Key="LinkLabelStyle" TargetType="Label">
        <Setter Property="FontSize"          Value="13" />
        <Setter Property="TextColor"         Value="{StaticResource LinkTextColor}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Margin"            Value="0,4,0,0" />
        <Setter Property="TextDecorations"   Value="Underline" />
    </Style>

    <Style x:Key="GeneralErrorLabelStyle" TargetType="Label">
        <Setter Property="FontSize"          Value="13" />
        <Setter Property="TextColor"         Value="{StaticResource ErrorTextColor}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Margin"            Value="0,8,0,8" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- ===================== -->
    <!-- Entry Styles          -->
    <!-- ===================== -->

    <Style x:Key="EntryStyle" TargetType="Entry">
        <Setter Property="BackgroundColor"   Value="{StaticResource EntryBackgroundColor}" />
        <Setter Property="TextColor"         Value="{StaticResource PrimaryTextColor}" />
        <Setter Property="PlaceholderColor"  Value="{StaticResource PlaceholderTextColor}" />
        <Setter Property="FontSize"          Value="15" />
        <Setter Property="Margin"            Value="0,0,0,2" />
        <Setter Property="HeightRequest"     Value="44" />
    </Style>

    <!-- ===================== -->
    <!-- Button Styles         -->
    <!-- ===================== -->

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor"   Value="{StaticResource AccentColor}" />
        <Setter Property="TextColor"         Value="#FFFFFF" />
        <Setter Property="FontSize"          Value="16" />
        <Setter Property="FontAttributes"    Value="Bold" />
        <Setter Property="CornerRadius"      Value="8" />
        <Setter Property="HeightRequest"     Value="50" />
        <Setter Property="Margin"            Value="0,16,0,8" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor"   Value="Transparent" />
        <Setter Property="TextColor"         Value="{StaticResource AccentColor}" />
        <Setter Property="FontSize"          Value="14" />
        <Setter Property="BorderColor"       Value="{StaticResource AccentColor}" />
        <Setter Property="BorderWidth"       Value="1" />
        <Setter Property="CornerRadius"      Value="8" />
        <Setter Property="HeightRequest"     Value="44" />
        <Setter Property="Margin"            Value="0,4,0,4" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <!-- ===================== -->
    <!-- Border/Card Styles    -->
    <!-- ===================== -->

    <Style x:Key="EntryBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource EntryBackgroundColor}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource EntryBorderColor}" />
        <Setter Property="Padding"         Value="8,0" />
        <Setter Property="Margin"          Value="0,0,0,2" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="6" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackgroundColor}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"          Value="{StaticResource BorderColor}" />
        <Setter Property="Padding"         Value="24" />
        <Setter Property="Margin"          Value="0" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="12" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== -->
    <!-- ActivityIndicator     -->
    <!-- ===================== -->

    <Style x:Key="LoadingIndicatorStyle" TargetType="ActivityIndicator">
        <Setter Property="Color"             Value="{StaticResource AccentColor}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Margin"            Value="0,8,0,8" />
    </Style>

</ResourceDictionary>

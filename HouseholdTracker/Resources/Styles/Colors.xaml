<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ===================== -->
    <!-- Background Colours    -->
    <!-- ===================== -->

    <!-- Main page background -->
    <Color x:Key="PageBackgroundColor">#FDF8F2</Color>
    <!-- Card or panel background -->
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>

    <!-- ===================== -->
    <!-- Text Colours          -->
    <!-- ===================== -->

    <!-- Primary text -->
    <Color x:Key="PrimaryTextColor">#1A1A1A</Color>
    <!-- Secondary/muted text -->
    <Color x:Key="SecondaryTextColor">#6B6B6B</Color>
    <!-- Placeholder text in Entry fields -->
    <Color x:Key="PlaceholderTextColor">#AAAAAA</Color>
    <!-- Error message text -->
    <Color x:Key="ErrorTextColor">#CC2929</Color>
    <!-- Link text colour -->
    <Color x:Key="LinkTextColor">#2E6DA4</Color>

    <!-- ===================== -->
    <!-- Brand / Accent        -->
    <!-- ===================== -->

    <!-- Primary accent used for buttons and highlights -->
    <Color x:Key="AccentColor">#4A7C59</Color>
    <!-- Darker shade for pressed button states -->
    <Color x:Key="AccentDarkColor">#355C40</Color>
    <!-- Light tint used for subtle highlights -->
    <Color x:Key="AccentLightColor">#D4E8DA</Color>

    <!-- ===================== -->
    <!-- Input Fields          -->
    <!-- ===================== -->

    <!-- Entry field background -->
    <Color x:Key="EntryBackgroundColor">#FFFFFF</Color>
    <!-- Entry field border -->
    <Color x:Key="EntryBorderColor">#CCCCCC</Color>
    <!-- Entry field border when focused -->
    <Color x:Key="EntryBorderFocusedColor">#4A7C59</Color>

    <!-- ===================== -->
    <!-- Borders / Dividers    -->
    <!-- ===================== -->

    <Color x:Key="DividerColor">#E0E0E0</Color>
    <Color x:Key="BorderColor">#DDDDDD</Color>

    <!-- ===================== -->
    <!-- Semantic Colours      -->
    <!-- ===================== -->

    <Color x:Key="SuccessColor">#2E7D32</Color>
    <Color x:Key="WarningColor">#F57C00</Color>
    <Color x:Key="DangerColor">#CC2929</Color>

</ResourceDictionary>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HouseholdTracker.Pages.MyTrackingPage"
    Title="My Tracking">

    <VerticalStackLayout
        Padding="32"
        Spacing="16"
        VerticalOptions="Center">

        <Label
            Text="Welcome to Household Tracker"
            Style="{StaticResource PageTitleStyle}" />

        <Label
            Text="Your tracking dashboard will appear here."
            Style="{StaticResource PageSubtitleStyle}" />

    </VerticalStackLayout>

</ContentPage>

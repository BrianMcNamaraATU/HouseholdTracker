<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HouseholdTracker.Pages.ForgotPasswordPage"
    Title=""
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <!-- Title -->
            <Label
                Text="Household Tracker"
                Style="{StaticResource PageTitleStyle}"
                Margin="0,0,0,4" />
            <Label
                Text="Reset your password"
                Style="{StaticResource PageSubtitleStyle}" />

            <!-- Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="0">

                    <!-- Instructions -->
                    <Label
                        Text="Enter your email address and we will send you a temporary password."
                        FontSize="13"
                        TextColor="{StaticResource SecondaryTextColor}"
                        HorizontalTextAlignment="Center"
                        Margin="0,0,0,16" />

                    <!-- Success Message -->
                    <Border
                        IsVisible="{Binding SubmitSuccessful}"
                        BackgroundColor="{StaticResource AccentLightColor}"
                        StrokeThickness="0"
                        Padding="12"
                        Margin="0,0,0,16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="6" />
                        </Border.StrokeShape>
                        <Label
                            Text="{Binding SuccessMessage}"
                            FontSize="13"
                            TextColor="{StaticResource SuccessColor}"
                            HorizontalTextAlignment="Center" />
                    </Border>

                    <!-- Email -->
                    <Label
                        Text="Email Address"
                        Style="{StaticResource FieldLabelStyle}"
                        IsVisible="{Binding SubmitSuccessful, Converter={StaticResource InvertedBoolConverter}}" />
                    <Border
                        Style="{StaticResource EntryBorderStyle}"
                        IsVisible="{Binding SubmitSuccessful, Converter={StaticResource InvertedBoolConverter}}">
                        <Entry
                            Style="{StaticResource EntryStyle}"
                            Text="{Binding Email}"
                            Placeholder="Enter your email address"
                            Keyboard="Email"
                            MaxLength="50"
                            ReturnType="Done"
                            ReturnCommand="{Binding SubmitCommand}" />
                    </Border>
                    <Label
                        Text="{Binding EmailError}"
                        Style="{StaticResource ErrorLabelStyle}"
                        IsVisible="{Binding EmailError, Converter={StaticResource StringToBoolConverter}}" />

                    <!-- Loading Indicator -->
                    <ActivityIndicator
                        Style="{StaticResource LoadingIndicatorStyle}"
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}" />

                    <!-- Submit Button -->
                    <Button
                        Text="Send Temporary Password"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SubmitCommand}"
                        IsVisible="{Binding SubmitSuccessful, Converter={StaticResource InvertedBoolConverter}}" />

                    <!-- Back to Login -->
                    <Label
                        Text="Back to Sign In"
                        Style="{StaticResource LinkLabelStyle}"
                        Margin="0,12,0,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackToLoginTapped" />
                        </Label.GestureRecognizers>
                    </Label>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

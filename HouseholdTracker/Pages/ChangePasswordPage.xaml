<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HouseholdTracker.Pages.ChangePasswordPage"
    Title=""
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <!-- Title -->
            <Label
                Text="Household Tracker"
                Style="{StaticResource PageTitleStyle}"
                Margin="0,0,0,4" />
            <Label
                Text="Change your password"
                Style="{StaticResource PageSubtitleStyle}" />

            <!-- Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="0">

                    <!-- Instructions (shown only when forced) -->
                    <Border
                        IsVisible="{Binding IsForced}"
                        BackgroundColor="{StaticResource AccentLightColor}"
                        StrokeThickness="0"
                        Padding="12"
                        Margin="0,0,0,16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="6" />
                        </Border.StrokeShape>
                        <Label
                            Text="You must set a new password before continuing."
                            FontSize="13"
                            TextColor="{StaticResource SuccessColor}"
                            HorizontalTextAlignment="Center" />
                    </Border>

                    <!-- Current Password -->
                    <Label Text="Current Password" Style="{StaticResource FieldLabelStyle}" />
                    <Border Style="{StaticResource EntryBorderStyle}">
                        <Entry
                            x:Name="CurrentPasswordEntry"
                            Style="{StaticResource EntryStyle}"
                            Text="{Binding CurrentPassword}"
                            Placeholder="Enter your current password"
                            IsPassword="True"
                            ReturnType="Next"
                            ReturnCommand="{Binding Source={x:Reference NewPasswordEntry}, Path=Focus}" />
                    </Border>
                    <Label
                        Text="{Binding CurrentPasswordError}"
                        Style="{StaticResource ErrorLabelStyle}"
                        IsVisible="{Binding CurrentPasswordError, Converter={StaticResource StringToBoolConverter}}" />

                    <!-- New Password -->
                    <Label Text="New Password" Style="{StaticResource FieldLabelStyle}" Margin="0,8,0,4" />
                    <Border Style="{StaticResource EntryBorderStyle}">
                        <Entry
                            x:Name="NewPasswordEntry"
                            Style="{StaticResource EntryStyle}"
                            Text="{Binding NewPassword}"
                            Placeholder="Enter your new password"
                            IsPassword="True"
                            MaxLength="20"
                            ReturnType="Next"
                            ReturnCommand="{Binding Source={x:Reference ConfirmNewPasswordEntry}, Path=Focus}" />
                    </Border>
                    <Label
                        Text="{Binding NewPasswordError}"
                        Style="{StaticResource ErrorLabelStyle}"
                        IsVisible="{Binding NewPasswordError, Converter={StaticResource StringToBoolConverter}}" />

                    <!-- Confirm New Password -->
                    <Label Text="Confirm New Password" Style="{StaticResource FieldLabelStyle}" Margin="0,8,0,4" />
                    <Border Style="{StaticResource EntryBorderStyle}">
                        <Entry
                            x:Name="ConfirmNewPasswordEntry"
                            Style="{StaticResource EntryStyle}"
                            Text="{Binding ConfirmNewPassword}"
                            Placeholder="Confirm your new password"
                            IsPassword="True"
                            MaxLength="20"
                            ReturnType="Done"
                            ReturnCommand="{Binding ChangePasswordCommand}" />
                    </Border>
                    <Label
                        Text="{Binding ConfirmNewPasswordError}"
                        Style="{StaticResource ErrorLabelStyle}"
                        IsVisible="{Binding ConfirmNewPasswordError, Converter={StaticResource StringToBoolConverter}}" />

                    <!-- General Error -->
                    <Label
                        Text="{Binding GeneralError}"
                        Style="{StaticResource GeneralErrorLabelStyle}"
                        IsVisible="{Binding GeneralError, Converter={StaticResource StringToBoolConverter}}" />

                    <!-- Loading Indicator -->
                    <ActivityIndicator
                        Style="{StaticResource LoadingIndicatorStyle}"
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}" />

                    <!-- Change Password Button -->
                    <Button
                        Text="Change Password"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding ChangePasswordCommand}" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
